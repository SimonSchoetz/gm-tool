{
  "name": "gm-tool",
  "version": "1.0.0",
  "description": "Mono repo of the GM-Tool project",
  "homepage": "https://github.com/SimonSchoetz/gm-tool#readme",
  "bugs": {
    "url": "https://github.com/SimonSchoetz/gm-tool/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SimonSchoetz/gm-tool.git"
  },
  "author": "Simon Schötz",
  "type": "module",
  "scripts": {
    "test": "cd app && npm run test",
    "dev": "cd app && npm run dev",
    "web": "cd app && npm run web",
    "lint": "cd app && npx eslint .",
    "build-local": "cd app && npm run tauri build -- --debug",
    "create-release": "node scripts/create-release.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "simple-git-hooks": "latest"
  },
  "simple-git-hooks": {
    "prepare-commit-msg": "./.githooks/prepare-commit-msg $1 $2"
  }
}
