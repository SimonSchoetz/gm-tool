{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GM-Tool",
  "version": "0.1.1",
  "identifier": "com.gm-tool",
  "build": {
    "beforeDevCommand": "npm run web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GM Tool",
        "width": 1920,
        "height": 1080
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEyMDY5RThBRUEyN0ExMzMKUldRem9TZnFpcDRHRXQwb2hhVTF4bWVKd0prOTJWVG9nOVFFNE9LN1FIeG5rYXFlV0pDbFhUYWQK",
      "endpoints": [
        "https://github.com/SimonSchoetz/gm-tool/releases/latest/download/latest.json"
      ]
    }
  }
}
